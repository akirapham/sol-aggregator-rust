# Solana DEX Aggregator Configuration
# Copy this file to .env and modify the values as needed

# =============================================================================
# RPC Configuration
# =============================================================================
# Solana RPC endpoint
RPC_URL=
YELLOWSTONE_GRPC_URL=

# Commitment level: processed, confirmed, or finalized
COMMITMENT_LEVEL=processed

# =============================================================================
# Basic Settings
# =============================================================================
# Maximum slippage tolerance (as decimal, e.g., 0.05 for 5%)
MAX_SLIPPAGE=0.05

# Maximum number of routes to return
MAX_ROUTES=5

# =============================================================================
# Smart Routing Configuration
# =============================================================================
# Enable multi-hop routing (A→B→C paths)
ENABLE_MULTI_HOP=true

# Enable split trading across multiple DEXs
ENABLE_SPLIT_TRADING=true

# Enable arbitrage detection
ENABLE_ARBITRAGE_DETECTION=true

# Maximum number of hops for multi-hop routing
MAX_HOPS=3

# Minimum liquidity threshold (in lamports)
MIN_LIQUIDITY_THRESHOLD=1000000

# Price impact threshold (as decimal, e.g., 0.05 for 5%)
PRICE_IMPACT_THRESHOLD=0.05

# Enable route simulation before execution
ENABLE_ROUTE_SIMULATION=true

# Enable dynamic slippage adjustment
ENABLE_DYNAMIC_SLIPPAGE=true

# =============================================================================
# Gas Configuration
# =============================================================================
# Maximum gas price (in lamports)
MAX_GAS_PRICE=5000

# Priority fee (in lamports)
PRIORITY_FEE=1000

# Gas limit (compute units)
GAS_LIMIT=200000

# Optimize for speed vs cost (true/false)
OPTIMIZE_FOR_SPEED=false

# =============================================================================
# MEV Protection Configuration
# =============================================================================
# Use private mempool for MEV protection
USE_PRIVATE_MEMPOOL=false

# Maximum slippage tolerance for MEV protection (as decimal)
MAX_SLIPPAGE_TOLERANCE=0.01

# Minimum liquidity threshold for MEV protection (in lamports)
MIN_LIQUIDITY_THRESHOLD_MEV=10000000

# Maximum MEV risk tolerance: low, medium, high, critical
MAX_MEV_RISK_TOLERANCE=medium

# Use flashloan protection
USE_FLASHLOAN_PROTECTION=false

# =============================================================================
# Split Trading Configuration
# =============================================================================
# Maximum number of splits for a single trade
MAX_SPLITS=3

# Minimum amount per split (in lamports)
MIN_SPLIT_AMOUNT=1000000

# Maximum price impact per split (as decimal)
MAX_PRICE_IMPACT_PER_SPLIT=0.02

# Prefer low MEV routes for splitting
PREFER_LOW_MEV=true

# =============================================================================
# DEX Configuration
# =============================================================================
# Enable/disable specific DEXs (true/false)

# PumpFun (bonding curve-based)
ENABLE_PUMPFUN=true

# PumpFun Swap (traditional AMM)
ENABLE_PUMPFUN_SWAP=true

# Raydium (standard AMM)
ENABLE_RAYDIUM=true

# Raydium CPMM (concentrated liquidity)
ENABLE_RAYDIUM_CPMM=true

# Orca (including Whirlpools)
ENABLE_ORCA=true
